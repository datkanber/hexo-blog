// ============================================================
// Custom Variable Overrides — Academic, Clean, Professional
// ============================================================

// --- Brand: Single muted blue, no rainbow ---
$brand-primary    = #1a56db

// --- Brand text (site title) ---
$brand-color                 = white
$brand-hover-color           = white
$brand-color-dark            = white
$brand-hover-color-dark      = white

// --- Light Mode: Warm paper-like tones ---
$whitesmoke       = #fafaf9
$gainsboro        = #e7e5e4
$grey-lighter     = #d6d3d1
$grey-light       = #a8a29e
$grey             = #78716c
$grey-dark        = #57534e
$grey-dim         = #44403c
$black-light      = #292524
$black-dim        = #1c1917
$black-deep       = #0c0a09

// --- Text: High contrast, warm neutrals ---
$text-color                = #1c1917
$text-color-dark           = #d6d3d1
$link-color                = $brand-primary
$link-color-dark           = #93b4f4
$link-hover-color          = #1e40af
$link-hover-color-dark     = #bdd0fa
$link-decoration-color     = alpha($brand-primary, 0.25)

// --- Backgrounds: Paper-like warmth ---
$body-bg-color             = #f5f5f4
$body-bg-color-dark        = #1c1917
$content-bg-color          = #ffffff
$content-bg-color-dark     = #292524
$card-bg-color             = #fafaf9
$card-bg-color-dark        = #44403c
$menu-item-bg-color        = alpha($brand-primary, 0.06)
$menu-item-bg-color-dark   = alpha(#93b4f4, 0.1)

// --- Headband ---
$headband-height           = 3px

// --- Sidebar ---
$sidebar-nav-color         = unquote('var(--text-color)')
$sidebar-nav-hover-color   = unquote('var(--link-color)')
$sidebar-highlight         = unquote('var(--link-color)')
$site-author-image-width   = 120px
$site-author-image-border-width = 2px
$site-author-image-border-color = $gainsboro
$site-author-name-color    = unquote('var(--text-color)')
$site-description-color    = unquote('var(--text-color)')

// --- Button ---
$btn-default-radius             = 6px
$btn-default-bg                 = $brand-primary
$btn-default-color              = white
$btn-default-border-color       = $brand-primary
$btn-default-hover-bg           = #1e40af
$btn-default-hover-color        = white
$btn-default-hover-border-color = #1e40af

// --- Table ---
$table-border-color           = $gainsboro
$table-row-odd-bg-color       = #fafaf9
$table-row-odd-bg-color-dark  = #292524
$table-row-hover-bg-color     = alpha($brand-primary, 0.03)
$table-row-hover-bg-color-dark = alpha(#93b4f4, 0.06)

// --- Blockquote ---
$blockquote-color        = $grey-dim
$blockquote-color-dark   = $grey-light

// --- Selection ---
$selection-bg            = alpha($brand-primary, 0.15)
$selection-color         = $black-deep
$selection-bg-dark       = alpha(#93b4f4, 0.25)
$selection-color-dark    = #d6d3d1

// --- Box Shadow (Gemini) ---
$box-shadow-inner = 0 1px 3px 0 rgba(0, 0, 0, 0.06), 0 1px 2px -1px rgba(0, 0, 0, 0.06)

// --- Border Radius: Subtle ---
$border-radius-inner = 8px
$border-radius       = 8px

// --- Typography ---
$font-size-base          = 1em
$line-height-base        = 1.85
$line-height-code-block  = 1.7

// --- Content Width ---
$content-desktop         = 760px
$content-desktop-large   = 840px
$content-desktop-largest = 920px

// --- Back to Top ---
$b2t-opacity       = 0.7
$b2t-opacity-hover = 1
$b2t-color         = white
$b2t-bg-color      = $brand-primary

// --- Badge ---
$badge-padding         = 2px 8px
$badge-border-radius   = 4px
$badge-background      = alpha($brand-primary, 0.08)
$badge-color           = $brand-primary
