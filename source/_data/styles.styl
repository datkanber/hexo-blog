// ============================================================
// ACADEMIC DESIGN — Clean, Minimal, Scholarly
// All colors use CSS variables for proper dark mode support
// ============================================================

:root
  --accent: #1a56db
  --accent-hover: #1e40af
  --accent-bg: rgba(26, 86, 219, 0.05)
  --accent-border: rgba(26, 86, 219, 0.12)
  --border: rgba(0, 0, 0, 0.08)
  --border-strong: rgba(0, 0, 0, 0.14)
  --subtle-bg: rgba(0, 0, 0, 0.025)
  --code-color: #b91c1c
  --code-bg: rgba(0, 0, 0, 0.04)
  --table-header-bg: #f0efed
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.04)
  --shadow-md: 0 2px 4px -1px rgba(0, 0, 0, 0.06), 0 1px 2px -1px rgba(0, 0, 0, 0.04)
  --radius: 8px
  --transition: 0.2s ease

@media (prefers-color-scheme: dark)
  :root
    --accent: #6d9ef5
    --accent-hover: #93b4f4
    --accent-bg: rgba(109, 158, 245, 0.08)
    --accent-border: rgba(109, 158, 245, 0.18)
    --border: rgba(255, 255, 255, 0.08)
    --border-strong: rgba(255, 255, 255, 0.14)
    --subtle-bg: rgba(255, 255, 255, 0.03)
    --code-color: #f0a8a8
    --code-bg: rgba(255, 255, 255, 0.06)
    --table-header-bg: #3a3532
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.15)
    --shadow-md: 0 2px 4px -1px rgba(0, 0, 0, 0.2), 0 1px 2px -1px rgba(0, 0, 0, 0.15)


// ============================================================
// 1. GLOBAL TYPOGRAPHY
// ============================================================

body
  text-rendering: optimizeLegibility
  -webkit-font-smoothing: antialiased

html
  scroll-behavior: smooth

h1, h2, h3, h4, h5, h6
  font-family: 'Inter', sans-serif !important
  font-weight: 700
  letter-spacing: -0.01em
  line-height: 1.35
  color: var(--text-color)

h1
  font-size: 2em

h2
  font-size: 1.5em
  padding-bottom: 0.35em
  border-bottom: 1px solid var(--border)

h3
  font-size: 1.25em

.post-body p
  margin-bottom: 1.3em
  line-height: 1.9


// ============================================================
// 2. HEADBAND
// ============================================================

.headband
  background: var(--accent) !important
  height: 3px !important


// ============================================================
// 3. HEADER
// ============================================================

.site-title
  font-family: 'Inter', sans-serif !important
  font-size: 1.5em !important
  font-weight: 700 !important
  letter-spacing: -0.01em
  color: white !important

.site-subtitle
  font-family: 'Inter', sans-serif !important
  font-size: 0.78em !important
  font-weight: 400
  letter-spacing: 0.03em
  text-transform: uppercase
  opacity: 0.55
  color: rgba(255, 255, 255, 0.7) !important


// ============================================================
// 4. NAVIGATION
// ============================================================

.menu-item a
  border-radius: 4px !important
  padding: 5px 14px !important
  margin: 2px 3px !important
  transition: all var(--transition) !important
  font-weight: 500
  font-size: 0.88em
  &:hover
    background: var(--accent-bg) !important
    color: var(--accent) !important

.menu-item.menu-item-active a
  background: var(--accent) !important
  color: white !important

.menu .badge
  background: var(--accent-bg) !important
  color: var(--accent) !important
  border-radius: 4px !important
  padding: 1px 6px !important
  font-size: 0.75em
  font-weight: 600


// ============================================================
// 5. SIDEBAR
// ============================================================

.site-author-image
  width: 120px !important
  height: 120px !important
  border: 2px solid var(--border-strong) !important
  border-radius: 50% !important
  transition: all var(--transition)
  &:hover
    border-color: var(--accent)

.site-author-name
  font-family: 'Inter', sans-serif !important
  font-size: 1.2em !important
  font-weight: 700
  margin-top: 10px !important
  color: var(--text-color)

.site-description
  font-size: 0.82em !important
  line-height: 1.5
  opacity: 0.65

// Stats
.site-state
  margin-top: 14px !important
  padding: 14px 0 !important
  border-top: 1px solid var(--border)
  border-bottom: 1px solid var(--border)

.site-state-item
  .site-state-item-count
    font-size: 1.3em !important
    font-weight: 700
    color: var(--accent)
  .site-state-item-name
    font-size: 0.7em !important
    text-transform: uppercase
    letter-spacing: 0.06em
    opacity: 0.5
    font-weight: 500

// Social links
.links-of-author a
  display: inline-flex !important
  align-items: center
  gap: 5px
  padding: 5px 12px !important
  margin: 3px !important
  border-radius: 4px !important
  background: transparent !important
  border: 1px solid var(--border) !important
  color: var(--text-color) !important
  font-size: 0.8em !important
  font-weight: 500
  transition: all var(--transition) !important
  &:hover
    border-color: var(--accent) !important
    color: var(--accent) !important
    background: var(--accent-bg) !important

// Blog Roll
.links-of-blogroll-title
  font-family: 'Inter', sans-serif
  font-weight: 700
  font-size: 0.9em
  margin-top: 18px !important

.links-of-blogroll-item a
  font-size: 0.82em
  opacity: 0.75
  transition: all var(--transition)
  &:hover
    opacity: 1
    color: var(--accent) !important

// TOC
.post-toc .nav-item .nav-link
  font-size: 0.84em
  border-left: 2px solid transparent
  padding-left: 8px !important
  transition: all var(--transition)
  &:hover
    color: var(--accent) !important
    border-left-color: var(--accent)
  &.active
    color: var(--accent) !important
    font-weight: 600
    border-left-color: var(--accent)


// ============================================================
// 6. POST CARDS
// ============================================================

.post-block
  background: var(--content-bg-color) !important
  border-radius: var(--radius) !important
  padding: 32px 36px !important
  margin-bottom: 24px !important
  box-shadow: var(--shadow-sm) !important
  border: 1px solid var(--border)
  transition: box-shadow var(--transition), border-color var(--transition)
  &:hover
    box-shadow: var(--shadow-md) !important
    border-color: var(--border-strong)

.post-title,
.post-title-link
  font-family: 'Inter', sans-serif !important
  font-weight: 700 !important
  font-size: 1.55em !important
  line-height: 1.35 !important
  color: var(--text-color) !important
  transition: color var(--transition) !important
  &:hover
    color: var(--accent) !important

@media (prefers-color-scheme: dark)
  .site-author-name
    color: #fff

@media (max-width: 991px)
  .sidebar .site-author-name
    color: #fff
  .sidebar .site-description
    color: #d6d3d1

.post-meta
  font-size: 0.8em !important
  opacity: 0.6
  margin-top: 6px !important

a[rel="category"]
  color: var(--accent) !important
  font-weight: 500
  font-size: 0.88em


// ============================================================
// 7. READ MORE
// ============================================================

.post-button .btn
  background: var(--accent) !important
  color: white !important
  border: none !important
  border-radius: 4px !important
  padding: 8px 22px !important
  font-weight: 600 !important
  font-size: 0.85em !important
  transition: all var(--transition) !important
  &:hover
    background: var(--accent-hover) !important


// ============================================================
// 8. POST BODY
// ============================================================

.post-body
  font-size: 1em

  a
    color: var(--accent)
    text-decoration: none
    border-bottom: 1px solid var(--accent-border)
    transition: border-color var(--transition)
    &:hover
      border-bottom-color: var(--accent)

  blockquote
    border-left: 3px solid var(--accent) !important
    background: var(--accent-bg) !important
    padding: 14px 20px !important
    border-radius: 0 4px 4px 0
    margin: 20px 0 !important
    font-style: italic

  code
    background: var(--code-bg) !important
    color: var(--code-color) !important
    padding: 2px 6px !important
    border-radius: 3px !important
    font-size: 0.88em !important

  pre, figure.highlight
    border-radius: 6px !important
    border: 1px solid var(--border) !important

  img
    border-radius: 6px !important

  hr
    border: none
    height: 1px
    background: var(--border)
    margin: 32px 0

  ul, ol
    padding-left: 22px
    li
      margin-bottom: 5px
      line-height: 1.8


// ============================================================
// 9. TABLES
// ============================================================

.post-body table
  width: 100%
  border-collapse: collapse
  border: 1px solid var(--border)
  margin: 20px 0
  font-size: 0.92em

  th
    background: var(--table-header-bg) !important
    color: var(--text-color) !important
    font-weight: 600
    font-size: 0.88em
    text-align: left
    padding: 10px 14px !important
    border-bottom: 2px solid var(--border-strong)

  td
    padding: 9px 14px !important
    border-bottom: 1px solid var(--border)

  tr:hover td
    background: var(--subtle-bg)


// ============================================================
// 10. TAGS
// ============================================================

.post-footer
  margin-top: 28px !important
  padding-top: 18px !important
  border-top: 1px solid var(--border)

a.tag-link,
.post-tags a,
.tag-cloud a,
.tag-cloud-tags a
  display: inline-block !important
  padding: 3px 10px !important
  margin: 2px !important
  border-radius: 3px !important
  background: var(--accent-bg) !important
  border: 1px solid var(--accent-border) !important
  color: var(--accent) !important
  font-size: 0.8em !important
  font-weight: 500
  transition: all var(--transition) !important
  &:hover
    background: var(--accent) !important
    color: white !important
    border-color: var(--accent) !important


// ============================================================
// 11. CATEGORIES
// ============================================================

.category-list-link
  transition: color var(--transition)
  font-weight: 500
  &:hover
    color: var(--accent) !important

.category-list-count
  opacity: 0.6
  font-size: 0.82em


// ============================================================
// 12. PAGINATION
// ============================================================

.pagination .page-number
  border-radius: 4px !important
  margin: 0 2px !important
  font-weight: 600
  transition: all var(--transition)
  &:hover
    background: var(--accent-bg)
    color: var(--accent)
  &.current
    background: var(--accent) !important
    color: white !important


// ============================================================
// 13. FOOTER
// ============================================================

.footer
  border-top: 1px solid var(--border)
  padding: 24px 0 !important

.footer-inner
  font-size: 0.82em
  opacity: 0.7

.custom-footer-social
  display: flex
  justify-content: center
  gap: 12px
  margin-bottom: 10px

  a
    display: inline-flex
    align-items: center
    justify-content: center
    width: 36px
    height: 36px
    border-radius: 50%
    color: var(--text-color) !important
    font-size: 1em
    opacity: 0.5
    transition: all var(--transition)
    border: 1px solid var(--border)
    &:hover
      opacity: 1
      color: var(--accent) !important
      border-color: var(--accent)

.custom-footer-tagline
  font-size: 0.78em
  opacity: 0.45
  text-align: center
  letter-spacing: 0.02em


// ============================================================
// 14. BACK TO TOP
// ============================================================

.back-to-top
  background: var(--accent) !important
  color: white !important
  border-radius: 4px !important
  box-shadow: var(--shadow-md) !important
  transition: all var(--transition) !important
  &:hover
    background: var(--accent-hover) !important


// ============================================================
// 15. READING PROGRESS
// ============================================================

.reading-progress-bar
  background: var(--accent) !important
  height: 2px !important


// ============================================================
// 16. GITHUB BANNER
// ============================================================

.github-corner svg
  fill: var(--accent) !important
  color: white !important


// ============================================================
// 17. POST NAVIGATION
// ============================================================

.post-nav-item
  border-radius: var(--radius) !important
  border: 1px solid var(--border)
  transition: border-color var(--transition)
  &:hover
    border-color: var(--accent-border)

  .post-nav-item-title
    font-weight: 600
    font-size: 0.9em


// ============================================================
// 18. ARCHIVE
// ============================================================

.post-item
  margin: 8px 0 !important
  padding: 8px 16px !important
  border-radius: 4px
  transition: background var(--transition)
  &:hover
    background: var(--subtle-bg)

.collection-title
  font-family: 'Inter', sans-serif
  font-size: 1.3em
  font-weight: 700
  margin: 28px 0 12px !important
  padding-bottom: 6px
  border-bottom: 1px solid var(--border)


// ============================================================
// 19. COPYRIGHT
// ============================================================

.post-copyright
  background: var(--subtle-bg) !important
  border-left: 3px solid var(--accent) !important
  border-radius: 0 4px 4px 0 !important
  padding: 14px 18px !important
  font-size: 0.85em


// ============================================================
// 20. SCROLLBAR
// ============================================================

::-webkit-scrollbar
  width: 6px
  height: 6px

::-webkit-scrollbar-track
  background: transparent

::-webkit-scrollbar-thumb
  background: var(--border-strong)
  border-radius: 6px
  &:hover
    background: var(--accent)


// ============================================================
// 21. SELECTION
// ============================================================

::selection
  background: var(--accent-bg) !important

::-moz-selection
  background: var(--accent-bg) !important


// ============================================================
// 22. RESPONSIVE
// ============================================================

+mobile()
  .post-block
    padding: 22px 18px !important
    margin-bottom: 14px !important

  .post-title,
  .post-title-link
    font-size: 1.25em !important

  .site-author-image
    width: 90px !important
    height: 90px !important

+tablet()
  .post-block
    padding: 28px 30px !important
